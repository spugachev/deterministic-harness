# The one project-specific manifest dhx reads. Keys equal to dhx's built-in
# defaults are omitted (so `dhx config explain` shows them as "(default)").
# See: dhx config explain <gate>.

[meta]
schema_version = 1

[project]
name = "{{project}}"

[coverage]
# The verified-core crate(s) held to the high coverage bar; everything else in
# the workspace is excluded from the report. REQUIRED.
core = ["core"]

[targets]
# Role assignments cargo metadata can't infer. The starter scaffold is
# core-only, so the nightly/concurrency gates point at `core`. As you add a
# concurrency adapter crate or an integration-test crate, repoint these (and add
# `dst = { crate = "...", test = "..." }`, `fuzz = ["..."]`).
miri = "core"
tsan = "core"
loom = "core"
# pins live at .harness/pins/<name>.txt by convention (no [pins] table).

# No [fsm] section: the starter domain is not a state machine, so regen/TLA+/
# check-spec-sync stay dormant. If your domain IS an FSM, model it as a pure
# `fn next(state, event) -> Option<state>` and add:
#
#   [fsm]
#   source = "crates/core/src/domain/<your>.rs"
#   fn_name = "next"
#   state_enum = "YourState"
#   event_enum = "YourEvent"
#   generated_stem = "Lifecycle"   # → spec/tla/Lifecycle.{tla,cfg}, generated by `dhx regen`
#
# dhx then generates the TLA+ spec from your Rust and model-checks it. Each TLA+
# invariant needs an anti-vacuity entry in spec/tla/mutations.toml.
